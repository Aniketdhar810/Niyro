// firestore.rules
// Firestore security rules scoped to each authenticated user.
// All collections are under the path `users/{userId}`.
// Only the owner can read/write their own documents.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to verify request is from authenticated user and matches the path.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // All user‑level data.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
